# OpenAI (for Macro Sentinel, Strategist, Quant, Behavioral Skeptic, Synthesizer, Backtest Evaluator)
OPENAI_API_KEY=sk-...

# Anthropic (for Narrative Analyst, Contrarian, Risk Manager)
ANTHROPIC_API_KEY=sk-ant-...

# Google (for Sentiment Scout — Gemini 2.5 Flash)
GOOGLE_API_KEY=...

# Database (optional — defaults to local SQLite if not set)
# For Supabase/Streamlit Cloud/GitHub Actions, set to your Postgres connection string
# DATABASE_URL=postgresql://postgres:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Data Sources (all free-tier accounts available)
FRED_API_KEY=...        # https://fred.stlouisfed.org/docs/api/api_key.html
FINNHUB_API_KEY=...     # https://finnhub.io (free tier)
NEWSAPI_KEY=...         # Optional legacy fetcher
REDDIT_CLIENT_ID=...    # Optional legacy fetcher
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=narrative-trading-system/0.1
